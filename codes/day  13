 Q49. Input and Display Array
#include <stdio.h>

int main() {
    int n, i;
    scanf("%d", &n);

    int a[n];

    for(i = 0; i < n; i++)
        scanf("%d", &a[i]);

    for(i = 0; i < n; i++)
        printf("%d ", a[i]);

    return 0;
}
Q50. Sum and Average of Array
#include <stdio.h>

int main() {
    int n, i, sum = 0;
    scanf("%d", &n);

    int a[n];

    for(i = 0; i < n; i++) {
        scanf("%d", &a[i]);
        sum += a[i];
    }

    printf("Sum = %d\n", sum);
    printf("Average = %.2f", (float)sum / n);

    return 0;
}
Q51. Largest and Smallest Element
#include <stdio.h>

int main() {
    int n, i;
    scanf("%d", &n);

    int a[n];

    for(i = 0; i < n; i++)
        scanf("%d", &a[i]);

    int max = a[0], min = a[0];

    for(i = 1; i < n; i++) {
        if(a[i] > max)
            max = a[i];

        if(a[i] < min)
            min = a[i];
    }

    printf("Largest = %d\n", max);
    printf("Smallest = %d", min);

    return 0;
}
Q52. Count Even and Odd Elements
#include <stdio.h>

int main() {
    int n, i, even = 0, odd = 0;
    scanf("%d", &n);

    int a[n];

    for(i = 0; i < n; i++) {
        scanf("%d", &a[i]);

        if(a[i] % 2 == 0)
            even++;
        else
            odd++;
    }

    printf("Even = %d\n", even);
    printf("Odd = %d", odd);

    return 0;
}
