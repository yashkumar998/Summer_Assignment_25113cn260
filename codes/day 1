 Sum of First N Natural Numbers
C
#include <stdio.h>

int main() {
    int n, sum = 0;
    printf("Enter N: ");
    scanf("%d", &n);

    for(int i = 1; i <= n; i++)
        sum += i;

    printf("Sum = %d", sum);
    return 0;
}
2. Multiplication Table
C
#include <stdio.h>

int main() {
    int n;
    printf("Enter a number: ");
    scanf("%d", &n);

    for(int i = 1; i <= 10; i++)
        printf("%d x %d = %d\n", n, i, n * i);

    return 0;
}
3. Factorial of a Number
C
#include <stdio.h>

int main() {
    int n;
    long long fact = 1;

    printf("Enter a number: ");
    scanf("%d", &n);

    for(int i = 1; i <= n; i++)
        fact *= i;

    printf("Factorial = %lld", fact);
    return 0;
}
4. Count Digits
C
#include <stdio.h>

int main() {
    int n, count = 0;
    printf("Enter a number: ");
    scanf("%d", &n);

    while(n != 0) {
        count++;
        n /= 10;
    }

    printf("Digits = %d", count);
    return 0;
}
