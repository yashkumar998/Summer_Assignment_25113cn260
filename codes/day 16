Q61. Find Missing Number (1 to n)
#include <stdio.h>

int main() {
    int n, i, sum = 0;
    scanf("%d", &n);

    int a[n - 1];

    for(i = 0; i < n - 1; i++) {
        scanf("%d", &a[i]);
        sum += a[i];
    }

    printf("%d", n * (n + 1) / 2 - sum);

    return 0;
}
Q62. Maximum Frequency Element
#include <stdio.h>

int main() {
    int n, i, j, maxCount = 0, element;
    scanf("%d", &n);

    int a[n], visited[n];

    for(i = 0; i < n; i++) {
        scanf("%d", &a[i]);
        visited[i] = 0;
    }

    for(i = 0; i < n; i++) {
        if(visited[i]) continue;

        int count = 1;

        for(j = i + 1; j < n; j++) {
            if(a[i] == a[j]) {
                count++;
                visited[j] = 1;
            }
        }

        if(count > maxCount) {
            maxCount = count;
            element = a[i];
        }
    }

    printf("%d", element);

    return 0;
}
Q63. Find Pair with Given Sum
#include <stdio.h>

int main() {
    int n, i, j, sum;
    scanf("%d", &n);

    int a[n];

    for(i = 0; i < n; i++)
        scanf("%d", &a[i]);

    scanf("%d", &sum);

    for(i = 0; i < n; i++) {
        for(j = i + 1; j < n; j++) {
            if(a[i] + a[j] == sum)
                printf("%d %d\n", a[i], a[j]);
        }
    }

    return 0;
}
Q64. Remove Duplicates from Array
#include <stdio.h>

int main() {
    int n, i, j, k;
    scanf("%d", &n);

    int a[n];

    for(i = 0; i < n; i++)
        scanf("%d", &a[i]);

    for(i = 0; i < n; i++) {
        for(j = i + 1; j < n;) {
            if(a[i] == a[j]) {
                for(k = j; k < n - 1; k++)
                    a[k] = a[k + 1];
                n--;
            } else {
                j++;
            }
        }
    }

    for(i = 0; i < n; i++)
        printf("%d ", a[i]);

    return 0;
}
