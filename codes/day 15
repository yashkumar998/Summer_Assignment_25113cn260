 Q57. Reverse Array
#include <stdio.h>

int main() {
    int n, i, temp;
    scanf("%d", &n);

    int a[n];

    for(i = 0; i < n; i++)
        scanf("%d", &a[i]);

    for(i = 0; i < n / 2; i++) {
        temp = a[i];
        a[i] = a[n - i - 1];
        a[n - i - 1] = temp;
    }

    for(i = 0; i < n; i++)
        printf("%d ", a[i]);

    return 0;
}
Q58. Rotate Array Left (by 1)
#include <stdio.h>

int main() {
    int n, i, first;
    scanf("%d", &n);

    int a[n];

    for(i = 0; i < n; i++)
        scanf("%d", &a[i]);

    first = a[0];

    for(i = 0; i < n - 1; i++)
        a[i] = a[i + 1];

    a[n - 1] = first;

    for(i = 0; i < n; i++)
        printf("%d ", a[i]);

    return 0;
}
Q59. Rotate Array Right (by 1)
#include <stdio.h>

int main() {
    int n, i, last;
    scanf("%d", &n);

    int a[n];

    for(i = 0; i < n; i++)
        scanf("%d", &a[i]);

    last = a[n - 1];

    for(i = n - 1; i > 0; i--)
        a[i] = a[i - 1];

    a[0] = last;

    for(i = 0; i < n; i++)
        printf("%d ", a[i]);

    return 0;
}
Q60. Move Zeros to End
#include <stdio.h>

int main() {
    int n, i, j = 0;
    scanf("%d", &n);

    int a[n];

    for(i = 0; i < n; i++)
        scanf("%d", &a[i]);

    for(i = 0; i < n; i++)
        if(a[i] != 0)
            a[j++] = a[i];

    while(j < n)
        a[j++] = 0;

    for(i = 0; i < n; i++)
        printf("%d ", a[i]);

    return 0;
}
