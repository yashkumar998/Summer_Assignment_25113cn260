 Q113. Menu Driven Calculator
#include <stdio.h>

int main()
{
    int ch;
    float a,b;

    printf("1.Add\n2.Subtract\n3.Multiply\n4.Divide\n");
    printf("Enter Choice: ");
    scanf("%d",&ch);

    printf("Enter Two Numbers: ");
    scanf("%f%f",&a,&b);

    switch(ch)
    {
        case 1: printf("Answer = %.2f",a+b); break;
        case 2: printf("Answer = %.2f",a-b); break;
        case 3: printf("Answer = %.2f",a*b); break;
        case 4:
            if(b!=0)
                printf("Answer = %.2f",a/b);
            else
                printf("Division by zero not allowed");
            break;
        default:
            printf("Invalid Choice");
    }

    return 0;
}
Q114. Menu Driven Array Operations
#include <stdio.h>

int main()
{
    int a[100], n, i, sum = 0;

    printf("Enter Size: ");
    scanf("%d",&n);

    printf("Enter Elements:\n");
    for(i=0;i<n;i++)
        scanf("%d",&a[i]);

    for(i=0;i<n;i++)
        sum += a[i];

    printf("Sum = %d\n",sum);
    printf("Average = %.2f",(float)sum/n);

    return 0;
}
Q115. Menu Driven String Operations
#include <stdio.h>
#include <string.h>

int main()
{
    char str[100];

    printf("Enter String: ");
    scanf("%s",str);

    printf("Length = %lu\n",strlen(str));

    strrev(str);

    printf("Reverse = %s",str);

    return 0;
}
Q116. Inventory Management System
#include <stdio.h>

struct Item
{
    int id, qty;
    char name[30];
};

int main()
{
    struct Item i;

    printf("Enter Item ID: ");
    scanf("%d",&i.id);

    printf("Enter Item Name: ");
    scanf("%s",i.name);

    printf("Enter Quantity: ");
    scanf("%d",&i.qty);

    printf("\nItem Details\n");
    printf("ID : %d\n",i.id);
    printf("Name : %s\n",i.name);
    printf("Quantity : %d\n",i.qty);

    return 0;
}
