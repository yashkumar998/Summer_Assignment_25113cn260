 Q29. Half Pyramid
#include <stdio.h>

int main() {
    int n;
    scanf("%d", &n);

    for(int i = 1; i <= n; i++) {
        for(int j = 1; j <= i; j++)
            printf("*");
        printf("\n");
    }

    return 0;
}
Q30. Number Triangle
#include <stdio.h>

int main() {
    int n;
    scanf("%d", &n);

    for(int i = 1; i <= n; i++) {
        for(int j = 1; j <= i; j++)
            printf("%d", j);
        printf("\n");
    }

    return 0;
}
Q31. Character Triangle
#include <stdio.h>

int main() {
    int n;
    scanf("%d", &n);

    for(int i = 0; i < n; i++) {
        for(int j = 0; j <= i; j++)
            printf("%c", 'A' + j);
        printf("\n");
    }

    return 0;
}
Q32. Repeated Number Pattern
#include <stdio.h>

int main() {
    int n;
    scanf("%d", &n);

    for(int i = 1; i <= n; i++) {
        for(int j = 1; j <= i; j++)
            printf("%d", i);
        printf("\n");
    }

    return 0;
}
