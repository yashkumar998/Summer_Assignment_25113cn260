 Q25. Recursive Factorial
#include <stdio.h>

int fact(int n) {
    if(n == 0 || n == 1)
        return 1;
    return n * fact(n - 1);
}

int main() {
    int n;
    scanf("%d", &n);
    printf("%d", fact(n));
    return 0;
}
Q26. Recursive Fibonacci
#include <stdio.h>

int fib(int n) {
    if(n == 0)
        return 0;
    if(n == 1)
        return 1;
    return fib(n - 1) + fib(n - 2);
}

int main() {
    int n;
    scanf("%d", &n);

    for(int i = 0; i < n; i++)
        printf("%d ", fib(i));

    return 0;
}
Q27. Recursive Sum of Digits
#include <stdio.h>

int sum(int n) {
    if(n == 0)
        return 0;
    return n % 10 + sum(n / 10);
}

int main() {
    int n;
    scanf("%d", &n);

    printf("%d", sum(n));

    return 0;
}
Q28. Recursive Reverse Number
#include <stdio.h>

int rev = 0;

int reverse(int n) {
    if(n == 0)
        return rev;

    rev = rev * 10 + n % 10;
    reverse(n / 10);
}

int main() {
    int n;
    scanf("%d", &n);

    printf("%d", reverse(n));

    return 0;
}
