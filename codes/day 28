 Q109. Library Management System
#include <stdio.h>

struct Book
{
    int id;
    char name[50];
    char author[50];
};

int main()
{
    struct Book b;

    printf("Enter Book ID: ");
    scanf("%d",&b.id);

    printf("Enter Book Name: ");
    scanf("%s",b.name);

    printf("Enter Author Name: ");
    scanf("%s",b.author);

    printf("\nBook Details\n");
    printf("ID : %d\n",b.id);
    printf("Book : %s\n",b.name);
    printf("Author : %s\n",b.author);

    return 0;
}
Q110. Bank Account System
#include <stdio.h>

int main()
{
    int accNo;
    char name[30];
    float balance, deposit, withdraw;

    printf("Enter Account Number: ");
    scanf("%d",&accNo);

    printf("Enter Name: ");
    scanf("%s",name);

    printf("Enter Balance: ");
    scanf("%f",&balance);

    printf("Deposit Amount: ");
    scanf("%f",&deposit);
    balance += deposit;

    printf("Withdraw Amount: ");
    scanf("%f",&withdraw);

    if(withdraw <= balance)
        balance -= withdraw;
    else
        printf("Insufficient Balance\n");

    printf("Final Balance = %.2f",balance);

    return 0;
}
