Q19. Print Factors of a Number
C
#include <stdio.h>

int main() {
    int n, i;

    printf("Enter a number: ");
    scanf("%d", &n);

    printf("Factors are: ");

    for(i = 1; i <= n; i++) {
        if(n % i == 0)
            printf("%d ", i);
    }

    return 0;
}
Q20. Largest Prime Factor
C
#include <stdio.h>

int main() {
    int n, i, largest = 1;

    printf("Enter a number: ");
    scanf("%d", &n);

    for(i = 2; i <= n; i++) {
        while(n % i == 0) {
            largest = i;
            n /= i;
        }
    }

    printf("Largest Prime Factor = %d", largest);

    return 0;
}
