    for(i=0;i<3;i++)
        printf("%d %s\n",e[i].id,e[i].name);

    return 0;
}
Q120. Mini Project Using Arrays, Strings & Functions
#include <stdio.h>

void display(int a[], int n)
{
    int i;
    printf("Array Elements: ");
    for(i=0;i<n;i++)
        printf("%d ",a[i]);
}

int main()
{
    int a[5], i;

    printf("Enter 5 Elements:\n");

    for(i=0;i<5;i++)
        scanf("%d",&a[i]);

    display(a,5);

    return 0;
}
