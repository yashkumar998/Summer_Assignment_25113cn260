    scanf("%d", &n);

    int a[n];

    for(i = 0; i < n; i++)
        scanf("%d", &a[i]);

    int first = INT_MIN;
    int second = INT_MIN;

    for(i = 0; i < n; i++) {
        if(a[i] > first) {
            second = first;
            first = a[i];
        }
        else if(a[i] > second && a[i] != first) {
            second = a[i];
        }
    }

    printf("%d", second);

    return 0;
}
Q56. Find Duplicates in Array
#include <stdio.h>

int main() {
    int n, i, j;
    scanf("%d", &n);

    int a[n];

    for(i = 0; i < n; i++)
        scanf("%d", &a[i]);

    printf("Duplicates: ");

    for(i = 0; i < n; i++) {
        for(j = i + 1; j < n; j++) {
            if(a[i] == a[j]) {
                printf("%d ", a[i]);
                break;
            }
        }
    }

    return 0;
}
