 Q53. Linear Search
#include <stdio.h>

int main() {
    int n, i, key;
    scanf("%d", &n);

    int a[n];

    for(i = 0; i < n; i++)
        scanf("%d", &a[i]);

    scanf("%d", &key);

    for(i = 0; i < n; i++) {
        if(a[i] == key) {
            printf("Found at index %d", i);
            return 0;
        }
    }

    printf("Not Found");

    return 0;
}
Q54. Frequency of an Element
#include <stdio.h>

int main() {
    int n, i, key, count = 0;
    scanf("%d", &n);

    int a[n];

    for(i = 0; i < n; i++)
        scanf("%d", &a[i]);

    scanf("%d", &key);

    for(i = 0; i < n; i++) {
        if(a[i] == key)
            count++;
    }

    printf("%d", count);

    return 0;
}
Q55. Second Largest Element
