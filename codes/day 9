 Q33. Reverse Star Pattern
#include <stdio.h>

int main() {
    int n;
    scanf("%d", &n);

    for(int i = n; i >= 1; i--) {
        for(int j = 1; j <= i; j++)
            printf("*");
        printf("\n");
    }

    return 0;
}
Q34. Reverse Number Triangle
#include <stdio.h>

int main() {
    int n;
    scanf("%d", &n);

    for(int i = n; i >= 1; i--) {
        for(int j = 1; j <= i; j++)
            printf("%d", j);
        printf("\n");
    }

    return 0;
}
Q35. Repeated Character Pattern
#include <stdio.h>

int main() {
    int n;
    scanf("%d", &n);

    for(int i = 0; i < n; i++) {
        for(int j = 0; j <= i; j++)
            printf("%c", 'A' + i);
        printf("\n");
    }

    return 0;
}
