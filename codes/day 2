 Sum of Digits
C
#include <stdio.h>

int main() {
    int n, sum = 0;

    printf("Enter a number: ");
    scanf("%d", &n);

    while(n != 0) {
        sum += n % 10;
        n /= 10;
    }

    printf("Sum of digits = %d", sum);
    return 0;
}
6. Reverse a Number
C
#include <stdio.h>

int main() {
    int n, rev = 0;

    printf("Enter a number: ");
    scanf("%d", &n);

    while(n != 0) {
        rev = rev * 10 + n % 10;
        n /= 10;
    }

    printf("Reverse = %d", rev);
    return 0;
}
7. Product of Digits
C
#include <stdio.h>

int main() {
    int n, product = 1;

    printf("Enter a number: ");
    scanf("%d", &n);

    while(n != 0) {
        product *= n % 10;
        n /= 10;
    }

    printf("Product of digits = %d", product);
    return 0;
}
