Q86. Count Words in a Sentence
C
#include <stdio.h>

int main() {
    char str[200];
    int i, words = 1;

    printf("Enter a sentence: ");
    gets(str);

    for(i = 0; str[i] != '\0'; i++) {
        if(str[i] == ' ')
            words++;
    }

    printf("Number of words = %d", words);

    return 0;
}
Q87. Character Frequency
C
#include <stdio.h>

int main() {
    char str[100], ch;
    int i, count = 0;

    printf("Enter a string: ");
    gets(str);

    printf("Enter character to find frequency: ");
    scanf("%c", &ch);

    for(i = 0; str[i] != '\0'; i++) {
        if(str[i] == ch)
            count++;
    }

    printf("Frequency of '%c' = %d", ch, count);

    return 0;
}
Q88. Remove Spaces from String
C
#include <stdio.h>

int main() {
    char str[100];
    int i, j = 0;

    printf("Enter a string: ");
    gets(str);

    for(i = 0; str[i] != '\0'; i++) {
        if(str[i] != ' ')
            str[j++] = str[i];
    }

    str[j] = '\0';

    printf("String without spaces = %s", str);

    return 0;
}
