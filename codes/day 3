 Prime Number
C
#include <stdio.h>

int main() {
    int n, i, flag = 1;

    printf("Enter a number: ");
    scanf("%d", &n);

    if(n <= 1)
        flag = 0;

    for(i = 2; i <= n / 2; i++) {
        if(n % i == 0) {
            flag = 0;
            break;
        }
    }

    if(flag)
        printf("Prime");
    else
        printf("Not Prime");

    return 0;
}
10. Prime Numbers in a Range
C
#include <stdio.h>

int main() {
    int start, end, i, j, prime;

    printf("Enter start and end: ");
    scanf("%d%d", &start, &end);

    for(i = start; i <= end; i++) {
        if(i <= 1)
            continue;

        prime = 1;
        for(j = 2; j <= i / 2; j++) {
            if(i % j == 0) {
                prime = 0;
                break;
            }
        }

        if(prime)
            printf("%d ", i);
    }

    return 0;
}
11. GCD of Two Numbers
C
#include <stdio.h>

int main() {
    int a, b, temp;

    printf("Enter two numbers: ");
    scanf("%d%d", &a, &b);

    while(b != 0) {
        temp = b;
        b = a % b;
        a = temp;
    }

    printf("GCD = %d", a);
    return 0;
}
12. LCM of Two Numbers
C
#include <stdio.h>

int main() {
    int a, b, x, y, temp;

    printf("Enter two numbers: ");
    scanf("%d%d", &a, &b);

    x = a;
    y = b;

    while(y != 0) {
        temp = y;
        y = x % y;
        x = temp;
    }

    printf("LCM = %d", (a * b) / x);
    return 0;
}
